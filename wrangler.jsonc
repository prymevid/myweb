{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "perime",
  "compatibility_date": "2026-06-21",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "exclude": ["node_modules/**", ".wrangler/**", ".wranglerignore"]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}